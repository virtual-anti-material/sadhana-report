{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.svg", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/icons/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-users",
      "urls": ["/api/users"],
      "cacheConfig": { "maxSize": 5, "maxAge": "1h", "strategy": "freshness" }
    }
  ]
}
